-- // STATE FLAGS //
local PlayerESPEnabled  = false
local MetalESPEnabled   = false
local StarESPEnabled    = false
local BeeESPEnabled     = false
local KitRenderEnabled  = false
local JoinNotifyEnabled = false

-- // SHARED SPECIAL ESP ASSETS //
local STAR_ICONS = {
	CritStar     = "rbxassetid://9871798596",
	VitalityStar = "rbxassetid://9871799391"
}
local BEE_IMAGE = "rbxassetid://7343272839"

local starESPObjects = {}
local beeESPObjects = {}

-- // UTILS //
local function getKitInfo(player)
	local key = player:GetAttribute("PlayingAsKits")
	local data = key and KitData[key]
	return data and data.Name or "?", data and data.Image or ""
end

local function isTeammate(player)
	return player.Team ~= nil and LocalPlayer.Team ~= nil and player.Team == LocalPlayer.Team
end

local function getRoot(obj)
	if obj:IsA("Model") then return obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart") end
	return obj:IsA("BasePart") and obj or nil
end

-- // AIMLOCK SETTINGS //
local AimKey     = Enum.KeyCode.K
local Max_Range  = 50
local Smoothness = 0.35

-- // AIMLOCK STATE //
local AimlockEnabled = false
local IsAiming       = false
local CurrentTarget  = nil

-- // AIMLOCK UTILS //
local function isAlive(character)
	if not character or not character.Parent then return false end
	local hum = character:FindFirstChild("Humanoid")
	return hum and hum.Health > 0
end

-- Always returns the single closest enemy to the local player right now
local function getClosestTarget()
	local char = LocalPlayer.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
	local myRoot = char.HumanoidRootPart
	local best, bestDist = nil, Max_Range

	for _, p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Team ~= LocalPlayer.Team and p.Character and isAlive(p.Character) then
			local root = p.Character:FindFirstChild("HumanoidRootPart")
			if root then
				local worldDist = (root.Position - myRoot.Position).Magnitude
				if worldDist <= bestDist then
					bestDist = worldDist
					best = p.Character
				end
			end
		end
	end
	return best
end

UserInputService.InputBegan:Connect(function(i, g)
	if g then return end
	if AimlockEnabled and i.KeyCode == AimKey then
		IsAiming = not IsAiming
		if IsAiming then
			CurrentTarget = getClosestTarget()
			if not CurrentTarget then IsAiming = false end
		else
			CurrentTarget = nil
			if mouse1release then mouse1release() end
		end
	end
if FreecamEnabled and i.KeyCode == FreecamKey then
		if freecam_connection then
			freecam_connection:Disconnect(); freecam_connection = nil
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default
			Camera.CameraType = Enum.CameraType.Custom
			LocalPlayer.CameraMinZoomDistance = freecam_oldMinZoom
			LocalPlayer.CameraMaxZoomDistance = freecam_oldMaxZoom
			if freecam_humanoid then
				freecam_humanoid.WalkSpeed = freecam_oldWalkSpeed
				freecam_humanoid.JumpPower = freecam_oldJumpPower
				freecam_humanoid = nil
			end
		else
			freecam_camPos = Camera.CFrame.Position
			local x, y = Camera.CFrame:ToOrientation()
			freecam_pitch = math.deg(x)
			freecam_yaw = math.deg(y)
			Camera.CameraType = Enum.CameraType.Scriptable
			freecam_oldMinZoom = LocalPlayer.CameraMinZoomDistance
			freecam_oldMaxZoom = LocalPlayer.CameraMaxZoomDistance
			LocalPlayer.CameraMinZoomDistance = 0.5
			LocalPlayer.CameraMaxZoomDistance = 0.5
			UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
			local character = LocalPlayer.Character
			if character then
				freecam_humanoid = character:FindFirstChildOfClass("Humanoid")
				if freecam_humanoid then
					freecam_oldWalkSpeed = freecam_humanoid.WalkSpeed
					freecam_oldJumpPower = freecam_humanoid.JumpPower
					freecam_humanoid.WalkSpeed = 0
					freecam_humanoid.JumpPower = 0
				end
			end
			freecam_connection = RunService.RenderStepped:Connect(function()
				local delta = UserInputService:GetMouseDelta()
				freecam_yaw -= delta.X * freecam_mouseSensitivity
				freecam_pitch -= delta.Y * freecam_mouseSensitivity
				freecam_pitch = math.clamp(freecam_pitch, -freecam_maxPitch, freecam_maxPitch)
				local rotation = CFrame.Angles(0, math.rad(freecam_yaw), 0) * CFrame.Angles(math.rad(freecam_pitch), 0, 0)
				local direction = freecam_updateMovement()
				local moveVector = (rotation.LookVector * direction.Z) + (rotation.RightVector * direction.X) + Vector3.new(0, direction.Y, 0)
				if moveVector.Magnitude > 0 then freecam_camPos += moveVector.Unit * freecam_speed end
				Camera.CFrame = CFrame.new(freecam_camPos) * rotation
			end)
		end
	end)

RunService:BindToRenderStep("AimLock", 201, function()
	if not AimlockEnabled or not IsAiming then return end

	-- Always re-evaluate closest target every frame so we track whoever is nearest
	local newTarget = getClosestTarget()
	if newTarget ~= CurrentTarget then
		CurrentTarget = newTarget
	end

	if not CurrentTarget then
		IsAiming = false
		if mouse1release then mouse1release() end
		return
	end

	local torso = CurrentTarget:FindFirstChild("Torso") or CurrentTarget:FindFirstChild("UpperTorso") or CurrentTarget:FindFirstChild("HumanoidRootPart")
	if not torso then return end

	Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, torso.Position), Smoothness)

	local highlight = CurrentTarget:FindFirstChild("_DamageHighlight_")
	if not highlight or not highlight.Enabled then
		if mouse1press then mouse1press() end
	else
		if mouse1release then mouse1release() end
	end
end)

-- // PLAYER ESP //
local OUTLINE_TRANS       = 0
local TEAMMATE_FILL_TRANS = 0.55
local ENEMY_FILL_TRANS    = 0.8
local TEAMMATE_ICON_SIZE  = 32
local ENEMY_ICON_SIZE     = 30
local ESPObjects = {}
local ESPConnections = {}

local function getTeamColor(player)
	-- Use the player's actual TeamColor so orange teams get orange, blue teams get blue, etc.
	if player.TeamColor then
		return player.TeamColor.Color
	end
	return Color3.fromRGB(255, 80, 80) -- fallback red for teamless enemies
end

local function RemoveNametag(character)
	local head = character:FindFirstChild("Head")
	if not head then return end
	local tag = head:FindFirstChild("Nametag")
	if tag then tag:Destroy() end
end

local function DestroyESP(player)
	if ESPObjects[player] then
		for _, v in pairs(ESPObjects[player]) do if v and v.Parent then v:Destroy() end end
		ESPObjects[player] = nil
	end
	if ESPConnections[player] then ESPConnections[player]:Disconnect(); ESPConnections[player] = nil end
end

local function CreateESP(player)
	if player == LocalPlayer or not PlayerESPEnabled then return end
	local function Setup(character)
		DestroyESP(player)
		RemoveNametag(character)
		local humanoid = character:WaitForChild("Humanoid")
		local root     = character:WaitForChild("HumanoidRootPart")
		local head     = character:WaitForChild("Head")
		local teammate = isTeammate(player)
		local teamCol  = getTeamColor(player)

		local highlight = Instance.new("Highlight")
		highlight.Name = "PlayerHighlight"
		highlight.Adornee = character
		highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		highlight.OutlineTransparency = OUTLINE_TRANS
		highlight.FillColor = teamCol
		highlight.OutlineColor = teamCol
		highlight.FillTransparency = teammate and TEAMMATE_FILL_TRANS or ENEMY_FILL_TRANS
		highlight.Parent = character

		local billboard = Instance.new("BillboardGui")
		billboard.Name = "ESPBillboard"; billboard.Adornee = head; billboard.AlwaysOnTop = true; billboard.LightInfluence = 0; billboard.Parent = game.CoreGui

		local kitIcon = Instance.new("ImageLabel")
		kitIcon.Name = "KitIcon"; kitIcon.BackgroundTransparency = 0.2; kitIcon.BackgroundColor3 = Color3.fromRGB(20, 20, 25); kitIcon.BorderSizePixel = 0; kitIcon.ScaleType = Enum.ScaleType.Fit; kitIcon.Image = ""; kitIcon.Parent = billboard
		Instance.new("UICorner", kitIcon).CornerRadius = UDim.new(0, 5)

		local topLabel, botLabel
		if teammate then
			billboard.Size = UDim2.new(0, TEAMMATE_ICON_SIZE, 0, TEAMMATE_ICON_SIZE); billboard.StudsOffset = Vector3.new(0, 3.2, 0)
			kitIcon.Size = UDim2.new(1, 0, 1, 0); kitIcon.Position = UDim2.new(0, 0, 0, 0)
		else
			local icoS = ENEMY_ICON_SIZE
			billboard.Size = UDim2.new(0, 160, 0, icoS + 4); billboard.StudsOffset = Vector3.new(0, 2.2, 0)
			kitIcon.Size = UDim2.new(0, icoS, 0, icoS); kitIcon.Position = UDim2.new(0, 0, 0.5, -(icoS / 2))
			local textOffset = icoS + 4
			topLabel = Instance.new("TextLabel"); topLabel.Size = UDim2.new(1, -textOffset, 0, 22); topLabel.Position = UDim2.new(0, textOffset, 0, 0); topLabel.BackgroundTransparency = 1; topLabel.TextColor3 = Color3.fromRGB(255, 255, 255); topLabel.TextStrokeTransparency = 0; topLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0); topLabel.TextSize = 13; topLabel.Font = Enum.Font.GothamBold; topLabel.TextXAlignment = Enum.TextXAlignment.Left; topLabel.Parent = billboard
			botLabel = Instance.new("TextLabel"); botLabel.Size = UDim2.new(1, -textOffset, 0, 18); botLabel.Position = UDim2.new(0, textOffset, 0, 22); botLabel.BackgroundTransparency = 1; botLabel.TextColor3 = Color3.fromRGB(220, 220, 220); botLabel.TextStrokeTransparency = 0; botLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0); botLabel.TextSize = 12; botLabel.Font = Enum.Font.GothamBold; botLabel.TextXAlignment = Enum.TextXAlignment.Left; botLabel.Parent = billboard
		end
		ESPObjects[player] = { highlight, billboard }

		local connection
		connection = RunService.RenderStepped:Connect(function()
			if not character or not character.Parent then connection:Disconnect(); return end

			-- Re-apply highlight if it got removed by the game (death animations, respawn, etc.)
			if PlayerESPEnabled then
				local existing = character:FindFirstChild("PlayerHighlight")
				if not existing then
					-- Recreate a fresh highlight parented back to the character
					highlight.Parent = character
				elseif existing ~= highlight then
					-- A duplicate snuck in; destroy it and keep ours
					existing:Destroy()
					highlight.Parent = character
				end
			end

			-- Keep team colour up to date in case the player changes teams mid-game
			local currentTeamCol = getTeamColor(player)
			highlight.FillColor = currentTeamCol
			highlight.OutlineColor = currentTeamCol

			if not teammate then
				local hp   = math.floor(humanoid.Health)
				local dist = math.floor((Camera.CFrame.Position - root.Position).Magnitude)
				if topLabel then topLabel.Text = hp .. " HP" end
				if botLabel then botLabel.Text = dist .. "m" end
			end
		end)
		ESPConnections[player] = connection
		local _, kitImg = getKitInfo(player); kitIcon.Image = kitImg
	end
	if player.Character then Setup(player.Character) end
	player.CharacterAdded:Connect(function(char) if PlayerESPEnabled then Setup(char) end end)
end

-- // PERIODIC HIGHLIGHT REAPPLICATION //
-- Belt-and-suspenders: every 2 seconds walk every tracked player and force the
-- highlight back onto their character if something yanked it off.
task.spawn(function()
	while true do
		task.wait(2)
		if PlayerESPEnabled then
			for player, objs in pairs(ESPObjects) do
				local highlight = objs[1]
				if highlight and player.Character and player.Character.Parent then
					if not player.Character:FindFirstChild("PlayerHighlight") then
						highlight.Parent = player.Character
					end
				end
			end
		end
	end
end)

local function setPlayerESP(enabled)
	PlayerESPEnabled = enabled
	if enabled then for _, p in pairs(Players:GetPlayers()) do CreateESP(p) end else for _, p in pairs(Players:GetPlayers()) do DestroyESP(p) end end
end

-- // STAR & BEE ESP //
local function createSpecialESP(obj, iconId, isBee)
	local part = getRoot(obj)
	if not part then return end
	local gui = Instance.new("BillboardGui"); gui.Name = isBee and "BeeESP" or "StarESP"; gui.Size = UDim2.new(0, 36, 0, 52); gui.StudsOffset = Vector3.new(0, 3.5, 0); gui.AlwaysOnTop = true; gui.Adornee = part; gui.Enabled = isBee and BeeESPEnabled or StarESPEnabled; gui.Parent = part
	local card = Instance.new("Frame", gui); card.Size = UDim2.new(1, 0, 0, 35); card.BackgroundColor3 = Color3.fromRGB(18, 18, 18); card.BackgroundTransparency = 0.28; card.BorderSizePixel = 0; Instance.new("UICorner", card).CornerRadius = UDim.new(0, 6)
	local icon = Instance.new("ImageLabel", card); icon.Size = UDim2.new(0, 22, 0, 22); icon.Position = UDim2.new(0.5, -11, 0.5, -11); icon.BackgroundTransparency = 1; icon.Image = iconId; icon.ScaleType = Enum.ScaleType.Fit
	local distLabel = Instance.new("TextLabel", gui); distLabel.Size = UDim2.new(1, 0, 0, 14); distLabel.Position = UDim2.new(0, 0, 0, 38); distLabel.BackgroundTransparency = 1; distLabel.Font = Enum.Font.GothamBold; distLabel.TextSize = 10; distLabel.TextColor3 = Color3.fromRGB(255, 255, 255); distLabel.Text = "-- m"
	if isBee then beeESPObjects[obj] = {part = part, label = distLabel, gui = gui} else starESPObjects[obj] = {part = part, label = distLabel, gui = gui} end
end

local function handleSpecialAdded(obj)
	if STAR_ICONS[obj.Name] then createSpecialESP(obj, STAR_ICONS[obj.Name], false)
	elseif obj.Name == "Bee" then createSpecialESP(obj, BEE_IMAGE, true) end
end
workspace.DescendantAdded:Connect(handleSpecialAdded)
for _, obj in ipairs(workspace:GetDescendants()) do handleSpecialAdded(obj) end

-- // METAL ESP //
local function setMetalESP(enabled)
	MetalESPEnabled = enabled
	for _, obj in ipairs(workspace:GetChildren()) do
		if obj:IsA("BillboardGui") and obj.Name == "LootText" then obj.Enabled = enabled end
		if obj.Name == "LootCircle" then obj.Transparency = enabled and 0.35 or 1 end
	end
end

local function addESP(part)
	if part:FindFirstChild("LootESP") then return end
	local tag = Instance.new("StringValue"); tag.Name = "LootESP"; tag.Parent = part
	local circle = Instance.new("Part"); circle.Name = "LootCircle"; circle.Shape = Enum.PartType.Cylinder; circle.Size = Vector3.new(0.1, 5, 5); circle.CFrame = CFrame.new(part.Position - Vector3.new(0, part.Size.Y / 2 + 0.05, 0)) * CFrame.Angles(0, 0, math.rad(90)); circle.Anchored = false; circle.CanCollide = false; circle.Color = Color3.fromRGB(255, 210, 50); circle.Material = Enum.Material.Neon; circle.Transparency = MetalESPEnabled and 0.35 or 1; circle.Parent = workspace
	local weld = Instance.new("WeldConstraint"); weld.Part0 = circle; weld.Part1 = part; weld.Parent = circle
	local billboard = Instance.new("BillboardGui"); billboard.Name = "LootText"; billboard.Adornee = part; billboard.Size = UDim2.new(0, 120, 0, 50); billboard.StudsOffset = Vector3.new(0, 2.5, 0); billboard.AlwaysOnTop = true; billboard.Enabled = MetalESPEnabled; billboard.Parent = workspace
	local lootLabel = Instance.new("TextLabel"); lootLabel.Size = UDim2.new(1, 0, 0.55, 0); lootLabel.BackgroundTransparency = 1; lootLabel.Text = "Loot"; lootLabel.TextColor3 = Color3.fromRGB(255, 210, 50); lootLabel.TextSize = 15; lootLabel.Font = Enum.Font.GothamBold; lootLabel.Parent = billboard
	local distLabel = Instance.new("TextLabel"); distLabel.Name = "DistLabel"; distLabel.Size = UDim2.new(1, 0, 0.45, 0); distLabel.Position = UDim2.new(0, 0, 0.55, 0); distLabel.BackgroundTransparency = 1; distLabel.Text = "0m"; distLabel.TextColor3 = Color3.fromRGB(255, 255, 255); distLabel.TextSize = 13; distLabel.Font = Enum.Font.GothamBold; distLabel.Parent = billboard
	part.AncestryChanged:Connect(function() if not part:IsDescendantOf(workspace) then circle:Destroy(); billboard:Destroy() end end)
end

RunService.Heartbeat:Connect(function()
	local char = LocalPlayer.Character; local root = char and char:FindFirstChild("HumanoidRootPart")
	if not root then return end
	local pos = root.Position
	if MetalESPEnabled then
		for _, obj in ipairs(workspace:GetChildren()) do
			if obj:IsA("BillboardGui") and obj.Name == "LootText" then
				local dist = math.floor((pos - obj.Adornee.Position).Magnitude)
				local lbl = obj:FindFirstChild("DistLabel"); if lbl then lbl.Text = dist .. "m" end
				obj.Enabled = dist <= 500
			end
		end
	end
	if StarESPEnabled then for obj, data in pairs(starESPObjects) do if obj.Parent then data.label.Text = math.floor((pos - data.part.Position).Magnitude) .. " m" end end end
	if BeeESPEnabled then for obj, data in pairs(beeESPObjects) do if obj.Parent then data.label.Text = math.floor((pos - data.part.Position).Magnitude) .. " m" end end end
end)

local function scanModel(model) if model.Name == "Model" then for _, child in ipairs(model:GetChildren()) do if child.Name == "Part" and child:IsA("BasePart") then addESP(child) end end end end
task.spawn(function() for _, obj in ipairs(workspace:GetChildren()) do scanModel(obj) end end)
workspace.ChildAdded:Connect(function(obj) task.wait(0.1); scanModel(obj) end)

-- // KIT RENDER //
local kitRenderGui = nil; local kitPlayerRows = {}; local kitRunning = false
local function updateKitRow(player, scrollFrame)
	if player == LocalPlayer then return end
	local kit = player:GetAttribute("PlayingAsKits")
	if not kit or kit == "" then if kitPlayerRows[player] then kitPlayerRows[player]:Destroy(); kitPlayerRows[player] = nil end; return end
	if not kitPlayerRows[player] then
		local row = Instance.new("Frame"); row.Size = UDim2.new(1, -10, 0, 45); row.BackgroundColor3 = Color3.fromRGB(40, 40, 45); row.Parent = scrollFrame; Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)
		local kitImage = Instance.new("ImageLabel"); kitImage.Name = "KitImage"; kitImage.Size = UDim2.new(0, 40, 0, 40); kitImage.Position = UDim2.new(0, 3, 0.5, -20); kitImage.BackgroundColor3 = Color3.fromRGB(50, 50, 55); kitImage.ScaleType = Enum.ScaleType.Fit; kitImage.Parent = row; Instance.new("UICorner", kitImage).CornerRadius = UDim.new(0, 4)
		local nameLabel = Instance.new("TextLabel"); nameLabel.Name = "PlayerName"; nameLabel.Size = UDim2.new(1, -55, 0, 22); nameLabel.Position = UDim2.new(0, 50, 0, 2); nameLabel.BackgroundTransparency = 1; nameLabel.TextSize = 14; nameLabel.Font = Enum.Font.GothamBold; nameLabel.TextXAlignment = Enum.TextXAlignment.Left; nameLabel.Parent = row
		local kitLabel = Instance.new("TextLabel"); kitLabel.Name = "KitName"; kitLabel.Size = UDim2.new(1, -55, 0, 18); kitLabel.Position = UDim2.new(0, 50, 0, 24); kitLabel.BackgroundTransparency = 1; kitLabel.TextColor3 = Color3.fromRGB(180, 180, 180); kitLabel.TextSize = 12; kitLabel.Font = Enum.Font.Gotham; kitLabel.TextXAlignment = Enum.TextXAlignment.Left; kitLabel.Parent = row
		kitPlayerRows[player] = row
	end
	local row = kitPlayerRows[player]; local kitName, kitImage = getKitInfo(player)
	row.PlayerName.Text = player.DisplayName; row.PlayerName.TextColor3 = player.TeamColor and player.TeamColor.Color or Color3.fromRGB(255, 255, 255); row.KitName.Text = kitName; row.KitImage.Image = kitImage
end

local function setKitRender(enabled)
	KitRenderEnabled = enabled
	if enabled then
		kitRenderGui = Instance.new("ScreenGui"); kitRenderGui.Name = "KitViewer"; kitRenderGui.DisplayOrder = 999998; kitRenderGui.Parent = LocalPlayer.PlayerGui
		local frame = Instance.new("Frame"); frame.Size = UDim2.new(0, 340, 0, 400); frame.Position = UDim2.new(0.5, 150, 0.5, -200); frame.BackgroundColor3 = Color3.fromRGB(30, 30, 35); frame.Parent = kitRenderGui; Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
		local scrollFrame = Instance.new("ScrollingFrame"); scrollFrame.Size = UDim2.new(1, -10, 1, -45); scrollFrame.Position = UDim2.new(0, 5, 0, 40); scrollFrame.BackgroundTransparency = 1; scrollFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y; scrollFrame.Parent = frame
		Instance.new("UIListLayout", scrollFrame).Padding = UDim.new(0, 5)
		kitRunning = true; task.spawn(function() while kitRunning do task.wait(1); for _, p in pairs(Players:GetPlayers()) do updateKitRow(p, scrollFrame) end end end)
	else kitRunning = false; if kitRenderGui then kitRenderGui:Destroy() end end
end

