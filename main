	local function getColor(rawName)
		local name = rawName:lower():gsub(" ","_"):gsub("-","_")
		if BLOCK_COLORS[name] then return BLOCK_COLORS[name] end
		local bestKey, bestLen = nil, 0
		for key in pairs(BLOCK_COLORS) do
			if name:find(key, 1, true) and #key > bestLen then bestKey = key; bestLen = #key end
		end
		return bestKey and BLOCK_COLORS[bestKey] or nil
	end

	for _, desc in ipairs(workspace:GetDescendants()) do
		if desc:IsA("BasePart") then
			for _, child in ipairs(desc:GetChildren()) do
				if child:IsA("Texture") or child:IsA("Decal") or child:IsA("SurfaceAppearance") then child:Destroy()
				elseif child:IsA("SpecialMesh") then child.TextureId = "" end
			end
			desc.Material = Enum.Material.SmoothPlastic
			local color = getColor(desc.Name)
			if not color then
				local ancestor = desc.Parent
				while ancestor and ancestor ~= workspace do
					color = getColor(ancestor.Name)
					if color then break end
					ancestor = ancestor.Parent
				end
			end
			desc.Color = color or Color3.fromRGB(160, 160, 160)
		end
	end

	workspace.DescendantAdded:Connect(function(obj)
		task.defer(function()
			if not obj or not obj.Parent then return end
			if obj:IsA("BasePart") then
				for _, child in ipairs(obj:GetChildren()) do
					if child:IsA("Texture") or child:IsA("Decal") or child:IsA("SurfaceAppearance") then child:Destroy()
					elseif child:IsA("SpecialMesh") then child.TextureId = "" end
				end
				obj.Material = Enum.Material.SmoothPlastic
				local color = getColor(obj.Name)
				if not color then
					local ancestor = obj.Parent
					while ancestor and ancestor ~= workspace do
						color = getColor(ancestor.Name)
						if color then break end
						ancestor = ancestor.Parent
					end
				end
				obj.Color = color or Color3.fromRGB(160, 160, 160)
			end
		end)
	end)
end)

switchTab("Combat")
UserInputService.InputBegan:Connect(function(i, g) if not g and i.KeyCode == Enum.KeyCode.RightShift then main.Visible = not main.Visible end end)
