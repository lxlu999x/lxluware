		enabled = not enabled
		row.BackgroundColor3 = enabled and Color3.fromRGB(22, 22, 22) or Color3.fromRGB(26, 26, 26)
		stroke.Color = enabled and Color3.fromRGB(220, 220, 220) or Color3.fromRGB(40, 40, 40)
		lbl.TextColor3 = enabled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(120, 120, 120)
		pill.BackgroundColor3 = enabled and Color3.fromRGB(240, 240, 240) or Color3.fromRGB(42, 42, 42)
		dot.BackgroundColor3 = enabled and Color3.fromRGB(17, 17, 17) or Color3.fromRGB(80, 80, 80)
		dot.Position = enabled and UDim2.new(0, 19, 0.5, -5) or UDim2.new(0, 3, 0.5, -5)
