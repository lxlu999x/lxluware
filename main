local tabPages, tabButtons = {}, {}
local function switchTab(name)
	for n, p in pairs(tabPages) do p.Visible = (n == name) end
	for n, b in pairs(tabButtons) do b.TextColor3 = (n == name) and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(90, 90, 90); local l = b:FindFirstChild("ActiveLine"); if l then l.Visible = (n == name) end end
end

local function makeTab(name)
	local btn = Instance.new("TextButton"); btn.Size = UDim2.new(0, 80, 1, 0); btn.BackgroundTransparency = 1; btn.Text = name; btn.TextColor3 = Color3.fromRGB(90, 90, 90); btn.TextSize = 11; btn.Font = Enum.Font.GothamBold; btn.Parent = tabButtonsContainer
	local activeLine = Instance.new("Frame"); activeLine.Name = "ActiveLine"; activeLine.Size = UDim2.new(1, -16, 0, 1); activeLine.Position = UDim2.new(0, 8, 1, -1); activeLine.BackgroundColor3 = Color3.fromRGB(255, 255, 255); activeLine.Visible = false; activeLine.Parent = btn
	local page = Instance.new("Frame"); page.Size = UDim2.new(1, 0, 0, 0); page.BackgroundTransparency = 1; page.AutomaticSize = Enum.AutomaticSize.Y; page.Visible = false; page.Parent = contentArea
	Instance.new("UIListLayout", page).Padding = UDim.new(0, 4); Instance.new("UIPadding", page).PaddingLeft = UDim.new(0, 8); page.UIPadding.PaddingRight = UDim.new(0, 8); page.UIPadding.PaddingTop = UDim.new(0, 8); page.UIPadding.PaddingBottom = UDim.new(0, 8)
	tabPages[name], tabButtons[name] = page, btn
	btn.MouseButton1Click:Connect(function() switchTab(name) end)
	return page
end

