	local lbl = Instance.new("TextLabel"); lbl.Size = UDim2.new(1, -10, 1, 0); lbl.Position = UDim2.new(0, 10, 0, 0); lbl.BackgroundTransparency = 1; lbl.Text = labelText; lbl.TextColor3 = Color3.fromRGB(200, 200, 200); lbl.TextSize = 12; lbl.Font = Enum.Font.GothamBold; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Parent = row
	local btn = Instance.new("TextButton", row); btn.Size = UDim2.new(1, 0, 1, 0); btn.BackgroundTransparency = 1; btn.Text = ""
	btn.MouseButton1Click:Connect(function()
		if fired then return end
		fired = true
		stroke.Color = Color3.fromRGB(80, 200, 120)
		lbl.TextColor3 = Color3.fromRGB(80, 200, 120)
		lbl.Text = "✓ Done"
		onClick()
	end)
end

